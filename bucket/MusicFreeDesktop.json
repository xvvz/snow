{
    "version": "0.0.8",
    "description": "插件化、定制化、无广告的免费音乐播放器",
    "homepage": "https://github.com/maotoumao/MusicFreeDesktop",
    "license": "GPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/maotoumao/MusicFreeDesktop/releases/download/v0.0.8/MusicFree-0.0.8-win32-x64-portable.zip",
            "hash": "b84ef7feced17a95dd704db9968867726008d782619d511656e5ece059951399"
        }
    },
    "bin": "MusicFree.exe",
    "shortcuts": [
        [
            "MusicFree.exe",
            "MusicFree"
        ]
    ],
    "installer": {
        "script": [
            "# 找到下载的原始 zip 文件",
            "$originalZip = Get-ChildItem \"$dir\\*.zip\" | Select-Object -First 1",
            "if ($originalZip) {",
            "    Expand-Archive -Path $originalZip.FullName -DestinationPath \"$dir\" -Force",
            "    Remove-Item -Path $originalZip.FullName -Force",
            "}",
            "",
            "# 递归解压所有嵌套的 zip 文件（直到没有 zip 为止）",
            "while ($zip = Get-ChildItem -Path \"$dir\" -Recurse -Filter *.zip | Select-Object -First 1) {",
            "    $dest = $zip.DirectoryName",
            "    Expand-Archive -Path $zip.FullName -DestinationPath $dest -Force",
            "    Remove-Item -Path $zip.FullName -Force",
            "}",
            "",
            "# 如果解压后只有一个顶级文件夹，把里面的内容上移到 $dir 根目录",
            "$items = Get-ChildItem -Path $dir -Force",
            "if ($items.Count -eq 1 -and $items[0].PSIsContainer) {",
            "    $subDir = $items[0]",
            "    Get-ChildItem -Path $subDir.FullName -Force | Move-Item -Destination $dir -Force",
            "    Remove-Item -Path $subDir.FullName -Force",
            "}"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/maotoumao/MusicFreeDesktop/releases/download/v$version/MusicFree-$version-win32-x64-portable.zip"
            }
        }
    }
}
