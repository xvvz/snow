{
    "name": "123pan",
    "version": "3.1.4.0",
    "description": "123云盘 - 免费高速云存储客户端",
    "homepage": "https://www.123pan.com/",
    "publisher": "123云盘",
    "license": {
        "identifier": "proprietary",
        "url": "https://www.123pan.com/UserAgreement"
    },
    "keywords": [
        "cloud",
        "storage",
        "pan",
        "123pan"
    ],
    "architecture": {
        "64bit": {
            "url": "https://app.123957.com/pc-pro/windows/314/123pan_3.1.4.exe",
            "hash": "c23d209ae2df7865d2d8881f65e64c7252b948504ca12d474115dbc0fd8e51b3"
        }
    },
    "installer": {
        "script": [
            "$installerPath = Join-Path $dir $fname",
            "$installDir = Join-Path $dir 'app'",
            "$innoArgs = @('/VERYSILENT', '/NORESTART', '/DIR=\"$installDir\"')",
            "$proc = Start-Process -FilePath $installerPath -ArgumentList $innoArgs -Wait -PassThru -NoNewWindow",
            "$validExit = @(0, 1641, 3010)",
            "if ($proc.ExitCode -notin $validExit) { throw \"安装失败，错误码: $($proc.ExitCode)\" }",
            "$exePath = Join-Path $installDir '123pan.exe'",
            "if (-not (Test-Path $exePath)) { throw \"安装完成，未检测到主程序\" }"
        ]
    },
    "uninstaller": {
        "script": [
            "$uninstExe = Join-Path $dir 'app\\unins000.exe'",
            "if (Test-Path $uninstExe) {",
            "    $uninstArgs = @('/VERYSILENT', '/NORESTART', '/SUPPRESSMSGBOXES', '/NOCOPYRIGHT')",
            "    $proc = Start-Process -FilePath $uninstExe -ArgumentList $uninstArgs -Wait -PassThru -NoNewWindow",
            "    $validExit = @(0, 1641, 3010)",
            "    if ($proc.ExitCode -notin $validExit) { Write-Warning \"卸载提示，错误码: $($proc.ExitCode)\" }",
            "}"
        ]
    },
    "bin": [
        "app\\123pan.exe"
    ],
    "shortcuts": [
        [
            "app\\123pan.exe",
            "123云盘"
        ]
    ],
    "checkver": {
        "url": "https://www.123pan.com/",
        "regex": "pc-pro/windows/(\\d+)/123pan_([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://app.123957.com/pc-pro/windows/$match1/123pan_$version.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    },
    "notes": [
        "默认静默安装，无弹窗",
        "启动命令: 123pan",
        "用户数据: %APPDATA%\\123pan",
        "缓存目录: %LOCALAPPDATA%\\123pan"
    ]
}
